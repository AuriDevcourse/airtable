# Copy to .env.local and fill in. NEVER commit .env.local.
# Airtable Personal Access Token. Needs data.records:read (public feeds) and
# data.records:write (the speaker sync writes into Marketing Project Overview).
AIRTABLE_TOKEN=patXXXXXXXX.XXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXX

AIRTABLE_SPEAKERS_TABLE=Speakers
# Only records with THIS checkbox ticked are ever returned to the public.
AIRTABLE_GATE_FIELD=On Website?

# In production set to your WordPress origin, e.g. https://techbbq.dk
ALLOWED_ORIGIN=*

# NISS 2026 (Nordic India Startup Summit Registrants). The gate is VIEW membership,
# not a status field. Table + view are pinned in lib/niss.ts; these are informational.
AIRTABLE_NISS_TABLE=tblfIPjV4t1c1628h
AIRTABLE_NISS_VIEW=viwRMZMX5NeN68XX7

# Speaker Hub — live TechBBQ Speakers 2026 roster. Supabase app (NOT Airtable).
# Reads the public `speaker_public_profiles` view with the anon/publishable key.
SPEAKERHUB_SUPABASE_URL=https://XXXXXXXX.supabase.co
SPEAKERHUB_SUPABASE_ANON_KEY=eyJXXXXXXXX

# Gates the /api/sync-speakers route (Supabase Speaker Hub -> Airtable). Vercel Cron
# and the GitHub Actions pinger send it as `Authorization: Bearer <CRON_SECRET>`.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=XXXXXXXX

# Basic auth for the internal /internal/* staff-email view (fails closed if unset)
INTERNAL_USER=techbbq
INTERNAL_PASS=change-me
